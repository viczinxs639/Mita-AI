// ===== 3. OLLAMA API =====
async function callOllama(userMessage, context) {
  const ollamaMessages = context.map(msg => ({
    role: msg.role === "assistant" ? "assistant" : "user",
    content: msg.content
  }));
  
  ollamaMessages.unshift({
    role: "system",
    content: "Você é a MITA, uma IA técnica e direta. Responda em português. Use formatação markdown para código."
  });
  
  const response = await fetch(`${ollamaUrl}/api/chat`, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      model: "llama3.2",
      messages: ollamaMessages,
      stream: false,
      options: {
        temperature: 0.7,
        num_predict: 1000
      }
    })
  });
  
  if (!response.ok) {
    throw new Error("Ollama não está rodando. Execute 'ollama serve' no terminal");
  }
  
  const data = await response.json();
  return data.message.content;
}

// ===== 4. MODO LOCAL =====
async function localResponse(userMessage, context) {
  const lowerMsg = userMessage.toLowerCase();
  
  if (lowerMsg.match(/^(oi|olá|ola|hey|e aí|eai)/i)) {
    const greetings = [
      `👋 Olá ${currentUser}! Como posso ajudar você hoje?`,
      `✨ Oi! Sou a MITA, sua assistente técnica.`,
      `🤖 Olá! Pronto para programar?`,
      `💡 Ei ${currentUser}! Vamos resolver problemas técnicos?`
    ];
    return greetings[Math.floor(Math.random() * greetings.length)];
  }
  
  if (lowerMsg.includes("código") || lowerMsg.includes("codigo")) {
    let lang = "javascript";
    if (lowerMsg.includes("python")) lang = "python";
    if (lowerMsg.includes("java")) lang = "java";
    if (lowerMsg.includes("html")) lang = "html";
    return generateCodeExample(lang);
  }
  
  if (lowerMsg.includes("explica") || lowerMsg.includes("o que é")) {
    const topic = userMessage.replace(/explica|o que é|como funciona/gi, "").trim();
    return explainTopic(topic || "programação");
  }
  
  if (lowerMsg.includes("obrigado") || lowerMsg.includes("valeu")) {
    return `🎯 Disponha ${currentUser}! Estou aqui para ajudar.`;
  }
  
  const lastMessages = context.slice(-3);
  const hasCode = lastMessages.some(m => m.content.includes("```"));
  
  if (hasCode) {
    return `**💻 Sobre o código que discutimos:**\n\nQuer que eu:\n1️⃣ Modifique o exemplo\n2️⃣ Explique linha por linha\n3️⃣ Mostre uma versão mais avançada\n\nMe diga o número ou descreva o que precisa!`;
  }
  
  return `**💡 MITA (Modo Local):**\n\nVocê perguntou: "${userMessage.substring(0, 100)}"\n\nPosso ajudar com:\n• 📝 **Código** - Gere exemplos em várias linguagens\n• 📚 **Explicações** - Conceitos técnicos claros\n• 🐛 **Debug** - Ajudo a resolver erros\n• 🎯 **Dicas** - Melhores práticas\n\n**💡 Dica:** Para respostas mais avançadas, configure OpenAI, Groq ou Ollama!`;
}

function generateCodeExample(language) {
  const examples = {
    javascript: `// Função exemplo em JavaScript
function processarDados(dados) {
    try {
        const resultado = dados.map(item => item * 2);
        console.log('Processado:', resultado);
        return resultado;
    } catch (erro) {
        console.error('Erro:', erro);
        return null;
    }
}

// Exemplo de uso
const dados = [1, 2, 3, 4, 5];
const resultado = processarDados(dados);`,
    
    python: `# Função exemplo em Python
def processar_dados(dados):
    try:
        resultado = [item * 2 for item in dados]
        print(f'Processado: {resultado}')
        return resultado
    except Exception as erro:
        print(f'Erro: {erro}')
        return None

# Exemplo de uso
dados = [1, 2, 3, 4, 5]
resultado = processar_dados(dados)`,
    
    java: `// Classe exemplo em Java
public class Processador {
    public static List<Integer> processar(List<Integer> dados) {
        try {
            return dados.stream()
                .map(n -> n * 2)
                .collect(Collectors.toList());
        } catch (Exception e) {
            System.err.println("Erro: " + e);
            return null;
        }
    }
    
    public static void main(String[] args) {
        List<Integer> dados = Arrays.asList(1, 2, 3, 4, 5);
        List<Integer> resultado = processar(dados);
        System.out.println(resultado);
    }
}`
  };
  
  const code = examples[language] || examples.javascript;
  
  return `**💻 Código em ${language.toUpperCase()}:**\n\n\`\`\`${language}\n${code}\n\`\`\`\n\n📌 Quer que eu modifique para sua necessidade específica?`;
}

function explainTopic(topic) {
  const explanations = {
    api: "**API (Application Programming Interface)** é um conjunto de regras que permite que diferentes softwares se comuniquem. Como um garçom em um restaurante, ela recebe seu pedido e traz a resposta do sistema.",
    "inteligência artificial": "**IA** é a área da computação que cria sistemas capazes de realizar tarefas que normalmente exigem inteligência humana: aprendizado, raciocínio, percepção e tomada de decisão.",
    blockchain: "**Blockchain** é um livro-razão digital descentralizado onde transações são registradas em blocos encadeados e criptografados, imutáveis e transparentes.",
    cloud: "**Cloud Computing** é a entrega de serviços de computação (servidores, armazenamento, bancos de dados) pela internet, pagando apenas pelo que usa."
  };
  
  for (const [key, explanation] of Object.entries(explanations)) {
    if (topic.toLowerCase().includes(key)) {
      return explanation + "\n\nQuer um exemplo prático ou mais detalhes?";
    }
  }
  
  return `**🧠 Explicação sobre "${topic}":**\n\n${topic} é um conceito fundamental em tecnologia. Basicamente, envolve a organização e processamento de informações para resolver problemas específicos.\n\nQuer que eu detalhe mais ou mostre exemplos práticos?`;
}

// ===== COMANDOS =====
function handleCommands(command) {
  const lower = command.toLowerCase();
  
  if (lower ===
