function renderMessages(messages) {
  if (!messagesContainer) return;
  
  if (!messages || messages.length === 0) {
    messagesContainer.innerHTML = `
      <div class="welcome-screen">
        <div class="welcome-icon">🤖</div>
        <h2>Bem-vindo à MITA</h2>
        <p>Sua assistente inteligente para programação, tecnologia e muito mais.</p>
        <div class="suggestions">
          <button class="suggestion-chip" data-msg="Me ensine sobre APIs">📚 Me ensine sobre APIs</button>
          <button class="suggestion-chip" data-msg="Gere um código em Python">💻 Gere um código em Python</button>
          <button class="suggestion-chip" data-msg="Explique inteligência artificial">🧠 Explique IA</button>
          <button class="suggestion-chip" data-msg="Como resolver um erro?">🐛 Como resolver um erro?</button>
        </div>
      </div>
    `;
    
    document.querySelectorAll('.suggestion-chip').forEach(chip => {
      chip.addEventListener('click', () => {
        userInput.value = chip.dataset.msg;
        sendMessage();
      });
    });
    return;
  }
  
  messagesContainer.innerHTML = messages.map((msg, idx) => `
    <div class="message ${msg.role} fade-in">
      <div class="message-avatar">${msg.role === 'user' ? '👤' : '🤖'}</div>
      <div class="message-content">
        ${formatMessageContent(msg.content)}
        ${document.getElementById("showTimestamps")?.checked ? `<div class="message-timestamp">${new Date(msg.timestamp).toLocaleTimeString()}</div>` : ''}
      </div>
    </div>
  `).join('');
  
  messagesContainer.scrollTop = messagesContainer.scrollHeight;
}

function formatMessageContent(content) {
  let formatted = content;
  
  // Código formatado
  formatted = formatted.replace(/```(\w+)?\n([\s\S]*?)```/g, (match, lang, code) => {
    return `<pre><code class="language-${lang || 'javascript'}">${escapeHtml(code)}</code></pre>`;
  });
  
  // Negrito
  formatted = formatted.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
  
  // Itálico
  formatted = formatted.replace(/\*(.*?)\*/g, '<em>$1</em>');
  
  // Imagens
  formatted = formatted.replace(/!\[(.*?)\]\((.*?)\)/g, '<img src="$2" alt="$1" onclick="window.showImageModal(this.src)" style="max-width: 100%; border-radius: 12px; cursor: pointer;">');
  
  // Links
  formatted = formatted.replace(/\[(.*?)\]\((.*?)\)/g, '<a href="$2" target="_blank" style="color: var(--accent-primary); text-decoration: none;">$1</a>');
  
  // Linhas
  formatted = formatted.replace(/\n/g, '<br>');
  
  return formatted;
}

function escapeHtml(text) {
  const div = document.createElement('div');
  div.textContent = text;
  return div.innerHTML;
}

// ===== RESPOSTA COM API =====
async function generateResponse(userMessage, context) {
  const lowerMsg = userMessage.toLowerCase();
  
  // Comandos primeiro
  if (lowerMsg.startsWith("/")) {
    return handleCommands(userMessage);
  }
  
  // Tentar usar API selecionada
  try {
    switch(apiMode) {
      case "openai":
        if (openaiKey) return await callOpenAI(userMessage, context);
        break;
      case "groq":
        if (groqKey) return await callGroq(userMessage, context);
        break;
      case "ollama":
        return await callOllama(userMessage, context);
      default:
        return await localResponse(userMessage, context);
    }
  } catch (error) {
    console.error("Erro na API:", error);
    showToast(`⚠️ Erro na API: ${error.message}. Usando modo local.`, "error");
    return await localResponse(userMessage, context);
  }
  
  return await localResponse(userMessage, context);
}

// ===== 1. OPENAI API =====
async function callOpenAI(userMessage, context) {
  const response = await fetch("https://api.openai.com/v1/chat/completions", {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
      "Authorization": `Bearer ${openaiKey}`
    },
    body: JSON.stringify({
      model: "gpt-3.5-turbo",
      messages: [
        { 
          role: "system", 
          content: `Você é a MITA (Machine Intelligence Thinking Assistant), uma IA técnica, direta e inteligente. 
          Responda em português de forma clara e profissional. Ajude com código, explicações técnicas e resolução de problemas.
          Seja contextual e mantenha a personalidade consistente. Use formatação markdown para código com \`\`\`.` 
        },
        ...context.slice(-10)
      ],
      temperature: 0.7,
      max_tokens: 1000
    })
  });
  
  if (!response.ok) {
    const error = await response.json();
    throw new Error(error.error?.message || "Erro na OpenAI");
  }
  
  const data = await response.json();
  return data.choices[0].message.content;
}

