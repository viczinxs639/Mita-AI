// ===== GERENCIAMENTO DE CHATS =====
function loadAllData() {
  const savedChats = localStorage.getItem(`mita_chats_${currentUser}`);
  if (savedChats) {
    chats = JSON.parse(savedChats);
  } else {
    const defaultChat = {
      id: Date.now(),
      title: "Conversa 1",
      messages: [{ role: "assistant", content: "Olá! Sou a MITA. Como posso ajudar você hoje?", timestamp: new Date().toISOString() }],
      createdAt: new Date().toISOString(),
      updatedAt: new Date().toISOString(),
      favorite: false,
      tags: []
    };
    chats = [defaultChat];
    currentChatId = defaultChat.id;
    saveChats();
  }
  
  if (!currentChatId && chats.length > 0) {
    currentChatId = chats[0].id;
  }
  
  renderChatsList();
  loadChat(currentChatId);
}

function saveChats() {
  localStorage.setItem(`mita_chats_${currentUser}`, JSON.stringify(chats));
  updateStats();
}

function renderChatsList() {
  const searchTerm = searchChats?.value.toLowerCase() || "";
  const filteredChats = chats.filter(chat => 
    chat.title.toLowerCase().includes(searchTerm) ||
    chat.messages.some(msg => msg.content.toLowerCase().includes(searchTerm))
  );
  
  if (document.getElementById("chatCount")) {
    document.getElementById("chatCount").innerText = filteredChats.length;
  }
  
  if (!chatsList) return;
  
  chatsList.innerHTML = filteredChats.map(chat => `
    <li class="chat-item ${chat.id === currentChatId ? 'active' : ''}" data-chat-id="${chat.id}">
      <div class="chat-info">
        <div class="chat-title">
          ${chat.favorite ? '<i class="fas fa-star" style="color: #fbbf24;"></i>' : '<i class="fas fa-comment"></i>'}
          ${escapeHtml(chat.title)}
        </div>
        <div class="chat-preview">${escapeHtml(chat.messages[chat.messages.length - 1]?.content.substring(0, 50) || 'Vazio')}...</div>
        <div class="chat-date">${new Date(chat.updatedAt).toLocaleDateString()}</div>
      </div>
      <div class="chat-actions">
        <button class="chat-action" onclick="window.editChatTitle(${chat.id})" title="Renomear"><i class="fas fa-pencil-alt"></i></button>
        <button class="chat-action" onclick="window.toggleFavoriteChat(${chat.id})" title="Favoritar"><i class="fas fa-star"></i></button>
        <button class="chat-action" onclick="window.deleteChat(${chat.id})" title="Excluir"><i class="fas fa-trash"></i></button>
      </div>
    </li>
  `).join('');
  
  document.querySelectorAll('.chat-item').forEach(item => {
    item.addEventListener('click', (e) => {
      if (!e.target.closest('.chat-actions')) {
        const chatId = parseInt(item.dataset.chatId);
        switchChat(chatId);
      }
    });
  });
}

function switchChat(chatId) {
  currentChatId = chatId;
  renderChatsList();
  loadChat(chatId);
}

function loadChat(chatId) {
  const chat = chats.find(c => c.id === chatId);
  if (chat) {
    if (currentChatTitle) currentChatTitle.innerText = chat.title;
    renderMessages(chat.messages);
  }
}

function createNewChat() {
  const newChat = {
    id: Date.now(),
    title: `Conversa ${chats.length + 1}`,
    messages: [{ role: "assistant", content: "Olá! Sou a MITA. Como posso ajudar você hoje?", timestamp: new Date().toISOString() }],
    createdAt: new Date().toISOString(),
    updatedAt: new Date().toISOString(),
    favorite: false,
    tags: []
  };
  chats.unshift(newChat);
  currentChatId = newChat.id;
  saveChats();
  renderChatsList();
  loadChat(currentChatId);
  showToast("Nova conversa criada!", "success");
}

window.deleteChat = function(chatId) {
  if (chats.length === 1) {
    showToast("Não é possível excluir a última conversa!", "warning");
    return;
  }
  
  chats = chats.filter(c => c.id !== chatId);
  if (currentChatId === chatId) {
    currentChatId = chats[0].id;
    loadChat(currentChatId);
  }
  saveChats();
  renderChatsList();
  showToast("Conversa excluída!", "success");
};

window.editChatTitle = function(chatId) {
  const chat = chats.find(c => c.id === chatId);
  const newTitle = prompt("Novo título:", chat.title);
  if (newTitle && newTitle.trim()) {
    chat.title = newTitle.trim();
    saveChats();
    renderChatsList();
    if (currentChatId === chatId && currentChatTitle) {
      currentChatTitle.innerText = chat.title;
    }
    showToast("Título atualizado!", "success");
  }
};

window.toggleFavoriteChat = function(chatId) {
  const chat = chats.find(c => c.id === chatId);
  chat.favorite = !chat.favorite;
  saveChats();
  renderChatsList();
  showToast(chat.favorite ? "Adicionado aos favoritos!" : "Removido dos favoritos!", "success");
};

function clearCurrentChat() {
  const chat = chats.find(c => c.id === currentChatId);
  if (chat && confirm("Tem certeza que deseja limpar esta conversa?")) {
    chat.messages = [{ role: "assistant", content: "Olá! Sou a MITA. Como posso ajudar você hoje?", timestamp: new Date().toISOString() }];
    chat.updatedAt = new Date().toISOString();
    saveChats();
    loadChat(currentChatId);
    showToast("Conversa limpa!", "success");
  }
}

