// MITA - Com tela de login e escolha de API

let currentUser = "guest";
let apiMode = "local";
let openaiKey = "";
let conversationHistory = [];

// Elementos da tela de login
const loginScreen = document.getElementById("loginScreen");
const mainApp = document.getElementById("mainApp");
const startBtn = document.getElementById("startMitaBtn");
const userNameInput = document.getElementById("userNameInput");
const apiRadio = document.querySelectorAll('input[name="apiMode"]');
const openaiKeyDiv = document.getElementById("openaiKeyInput");
const apiKeyInput = document.getElementById("apiKeyInput");

// Elementos da tela principal
const usernameSpan = document.getElementById("username");
const modeBadge = document.getElementById("modeBadge");
const userAvatar = document.getElementById("userAvatar");
const logoutBtn = document.getElementById("logoutBtn");
const messagesContainer = document.getElementById("messagesContainer");
const userInput = document.getElementById("userInput");
const sendBtn = document.getElementById("sendBtn");
const voiceBtn = document.getElementById("voiceBtn");
const historyList = document.getElementById("historyList");

// Mostrar/esconder campo da chave OpenAI
apiRadio.forEach(radio => {
  radio.addEventListener("change", (e) => {
    if (e.target.value === "openai") {
      openaiKeyDiv.style.display = "block";
      apiMode = "openai";
    } else {
      openaiKeyDiv.style.display = "none";
      apiMode = "local";
    }
  });
});

// Iniciar MITA
startBtn.addEventListener("click", () => {
  currentUser = userNameInput.value.trim() || "Visitante";
  usernameSpan.innerText = currentUser;
  userAvatar.innerText = currentUser[0].toUpperCase();
  
  // Configurar modo da API
  if (apiMode === "openai") {
    openaiKey = apiKeyInput.value.trim();
    if (!openaiKey.startsWith("sk-")) {
      alert("Chave OpenAI inválida! Usando modo local.");
      apiMode = "local";
      modeBadge.innerText = "Modo Local";
    } else {
      modeBadge.innerText = "Modo OpenAI";
    }
  } else {
    modeBadge.innerText = "Modo Local";
  }
  
  // Esconder login e mostrar app
  loginScreen.style.display = "none";
  mainApp.style.display = "flex";
  
  // Carregar histórico
  loadHistory();
});

// Logout
logoutBtn.addEventListener("click", () => {
  loginScreen.style.display = "flex";
  mainApp.style.display = "none";
  conversationHistory = [];
  userNameInput.value = "";
  apiKeyInput.value = "";
});

// Funções do chat
function loadHistory() {
  const saved = localStorage.getItem(`mita_history_${currentUser}_${apiMode}`);
  if (saved) {
    conversationHistory = JSON.parse(saved);
    renderMessages(conversationHistory);
  } else {
    conversationHistory = [
      { role: "assistant", content: `Olá! Sou a MITA (modo ${apiMode === "openai" ? "OpenAI" : "Local"}). Como posso ajudar você hoje?` }
    ];
    renderMessages(conversationHistory);
  }
  renderHistoryList();
}

function saveHistory() {
  localStorage.setItem(`mita_history_${currentUser}_${apiMode}`, JSON.stringify(conversationHistory));
  renderHistoryList();
}

function renderMessages(messages) {
  messagesContainer.innerHTML = "";
  messages.forEach(msg => {
    const div = document.createElement("div");
    div.className = `message ${msg.role}`;
    let content = msg.content;
    if (content.includes("```")) {
      content = content.replace(/```(\w+)?\n([\s\S]*?)```/g, '<pre><code>$2</code></pre>');
    } else {
      content = content.replace(/\n/g, "<br>");
    }
    div.innerHTML = content;
    messagesContainer.appendChild(div);
  });
  messagesContainer.scrollTop = messagesContainer.scrollHeight;
}

function renderHistoryList() {
  const userMessages = conversationHistory.filter(msg => msg.role === "user").slice(-10).reverse();
  historyList.innerHTML = userMessages.map(msg => 
    `<li onclick="loadFromHistory('${msg.content.replace(/'/g, "\\'").substring(0, 40)}')">
      ${msg.content.substring(0, 40)}...
    </li>`
  ).join("");
}

window.loadFromHistory = (text) => {
  userInput.value = text;
  sendMessage();
};

// Cérebro da MITA
async function getMitaResponse(userMessage, context) {
  if (apiMode === "openai" && openaiKey) {
    try {
      const response = await fetch("https://api.openai.com/v1/chat/completions", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "Authorization": `Bearer ${openaiKey}`
        },
        body: JSON.stringify({
          model: "gpt-3.5-turbo",
          messages: [
            { role: "system", content: "Você é a MITA, uma IA técnica, direta e inteligente. Responda de forma contextual." },
            ...context.slice(-10)
          ],
          temperature: 0.7
        })
      });
      const data = await response.json();
      return data.choices[0].message.content;
    } catch (error) {
      console.error("Erro na OpenAI:", error);
      return "⚠️ Erro na API. Usando modo local temporariamente.";
    }
  }
  
  // Modo local contextual
  const lowerMsg = userMessage.toLowerCase();
  
  if (lowerMsg.match(/^(oi|olá|ola|hey|e aí|eai)/i)) {
    return "👋 Olá! Sou a MITA. Como posso ajudar você hoje com tecnologia, programação ou engenharia?";
  }
  if (lowerMsg.includes("código") || lowerMsg.includes("codigo") || lowerMsg.includes("função")) {
    let lang = "javascript";
    if (lowerMsg.includes("python")) lang = "python";
    if (lowerMsg.includes("java")) lang = "java";
    return `📝 **Código em ${lang}:**\n\n\`\`\`${lang}\n// Exemplo\nfunction exemploMITA() {\n    console.log("MITA respondendo!");\n    return "Código gerado";\n}\n\`\`\`\n\nQuer que eu personalize?`;
  }
  if (lowerMsg.includes("explica") || lowerMsg.includes("o que é") || lowerMsg.includes("como funciona")) {
    return "🧠 **Explicação técnica:**\n\nIsso envolve algoritmos de processamento de linguagem natural e redes neurais. Quer um exemplo prático ou mais detalhes?";
  }
  if (lowerMsg.includes("obrigado") || lowerMsg.includes("valeu")) {
    return "🎯 Disponha! Estou aqui para ajudar. Precisa de mais alguma coisa?";
  }
  
  return `💡 **MITA responde:**\n\nVocê disse: "${userMessage}"\n\nPosso:\n- Gerar código específico\n- Explicar conceitos técnicos\n- Ajudar a resolver problemas\n\nO que você prefere?`;
}

async function sendMessage() {
  const query = userInput.value.trim();
  if (!query) return;

  conversationHistory.push({ role: "user", content: query });
  renderMessages(conversationHistory);
  userInput.value = "";
  saveHistory();

  const thinkingDiv = document.createElement("div");
  thinkingDiv.className = "message assistant";
  thinkingDiv.innerHTML = "⏳ MITA processando...";
  messagesContainer.appendChild(thinkingDiv);
  messagesContainer.scrollTop = messagesContainer.scrollHeight;

  await new Promise(resolve => setTimeout(resolve, 500));
  
  const answer = await getMitaResponse(query, conversationHistory);
  thinkingDiv.remove();

  conversationHistory.push({ role: "assistant", content: answer });
  renderMessages(conversationHistory);
  saveHistory();
}

// Voz
voiceBtn.addEventListener("click", () => {
  const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SpeechRecognition) {
    alert("Seu navegador não suporta reconhecimento de voz.");
    return;
  }
  const recognition = new SpeechRecognition();
  recognition.lang = "pt-BR";
  recognition.start();
  recognition.onresult = (event) => {
    userInput.value = event.results[0][0].transcript;
    sendMessage();
  };
});

sendBtn.addEventListener("click", sendMessage);
userInput.addEventListener("keypress", (e) => {
  if (e.key === "Enter" && !e.shiftKey) {
    e.preventDefault();
    sendMessage();
  }
});
